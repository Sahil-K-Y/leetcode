class Solution {
public:
    int minCost(vector<vector<int>>& grid, int k) {
        int m = grid.size(), n = grid[0].size();
        const int INF = 1e9;
        
        int N = m * n;
        vector<vector<int>> dist(k+1, vector<int>(N, INF));
        
        auto id = [&](int i, int j) { return i * n + j; };
        
        vector<pair<int,int>> cells;
        for(int i = 0; i < m; i++)
            for(int j = 0; j < n; j++)
                cells.push_back({grid[i][j], id(i,j)});
        
        sort(cells.begin(), cells.end());
        
        priority_queue<array<int,3>, vector<array<int,3>>, greater<>> pq;
        
        dist[0][0] = 0;
        pq.push({0, 0, 0}); // cost, nodeId, teleportsUsed
        
        vector<int> ptr(k+1, 0);
        vector<vector<bool>> activated(k+1, vector<bool>(N, false));
        
        while(!pq.empty()) {
            auto [cost, u, t] = pq.top();
            pq.pop();
            
            if(cost != dist[t][u]) continue;
            
            int i = u / n, j = u % n;
            if(i == m-1 && j == n-1) return cost;
            
            // Normal moves
            if(i+1 < m) {
                int v = id(i+1, j);
                int nc = cost + grid[i+1][j];
                if(nc < dist[t][v]) {
                    dist[t][v] = nc;
                    pq.push({nc, v, t});
                }
            }
            if(j+1 < n) {
                int v = id(i, j+1);
                int nc = cost + grid[i][j+1];
                if(nc < dist[t][v]) {
                    dist[t][v] = nc;
                    pq.push({nc, v, t});
                }
            }
            
            // Teleport layer unlock
            if(t < k) {
                while(ptr[t] < N && cells[ptr[t]].first <= grid[i][j]) {
                    int v = cells[ptr[t]++].second;
                    if(!activated[t+1][v] && cost < dist[t+1][v]) {
                        activated[t+1][v] = true;
                        dist[t+1][v] = cost;
                        pq.push({cost, v, t+1});
                    }
                }
            }
        }
        
        return -1;
    }
};


class Solution {
public:
    int minCost(vector<vector<int>>& grid, int k) {
        int m = grid.size(), n = grid[0].size();
        if (k && grid[0][0] >= grid[m - 1][n - 1]) {
            return 0;
        }
        int mx = 0;
        for (auto& row : grid) {
            mx = max(mx, ranges::max(row));
        }
        vector<int> suf_min_f(mx + 2, INT_MAX);
        vector<int> min_f(mx + 1);
        vector<int> f(n + 1);
        for (int t = 0; t <= k; t++) {
            ranges::fill(min_f, INT_MAX);
            ranges::fill(f, INT_MAX / 2);
            f[1] = -grid[0][0]; // 起点的成本不算
            for (auto& row : grid) {
                for (int j = 0; j < n; j++) {
                    int x = row[j];
                    f[j + 1] = min(min(f[j], f[j + 1]) + x, suf_min_f[x]);
                    min_f[x] = min(min_f[x], f[j + 1]);
                }
            }
            auto tmp = suf_min_f;
            for (int i = mx; i >= 0; i--) {
                suf_min_f[i] = min(suf_min_f[i + 1], min_f[i]);
            }
            if (suf_min_f == tmp) {
                break;
            }
        }
        return f[n];
    }
};
