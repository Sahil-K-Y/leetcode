class Solution {
public:
    bool hasAllCodes(string s, int k) {
        int n = s.size();
        
        if (n - k + 1 < (1 << k)) return false;
        
        vector<bool> seen(1 << k, false);
        int mask = 0;
        int allOnes = (1 << k) - 1;
        
        for (int i = 0; i < n; i++) {
            // Shift left and add current bit
            mask = ((mask << 1) & allOnes) | (s[i] - '0');
            
            if (i >= k - 1) {
                seen[mask] = true;
            }
        }
        
        for (bool x : seen) {
            if (!x) return false;
        }
        
        return true;
    }
};
