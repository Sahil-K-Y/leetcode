class Solution {
public:
    long long minimumCost(vector<int>& nums, int k, int dist) {
        int n = nums.size();
        long long ans = (long long)4e18;

        multiset<int> big, small;
        long long sumBig = 0;

        auto add = [&](int x) {
            small.insert(x);
        };

        auto rebalance = [&]() {
            // Fill big up to k-2 with smallest from small
            while ((int)big.size() < k - 2 && !small.empty()) {
                auto it = small.begin();
                int x = *it;
                small.erase(it);
                big.insert(x);
                sumBig += x;
            }
            // Ensure all in big are <= all in small
            if (!big.empty() && !small.empty()) {
                auto itBig = prev(big.end());
                auto itSmall = small.begin();
                if (*itBig > *itSmall) {
                    int xBig = *itBig, xSmall = *itSmall;
                    big.erase(itBig);
                    small.erase(itSmall);
                    big.insert(xSmall);
                    small.insert(xBig);
                    sumBig += (long long)xSmall - xBig;
                }
            }
        };

        auto rem = [&](int x) {
            auto it = big.find(x);
            if (it != big.end()) {
                sumBig -= x;
                big.erase(it);
            } else {
                it = small.find(x);
                if (it != small.end()) {
                    small.erase(it);
                }
            }
        };

        int R = 2; // window [i+1, R-1]; we start i = 1, so L = 2 initially
        for (int i = 1; i <= n - 2; ++i) {
            int L = i + 1;
            int maxR = min(i + dist, n - 1);

            // expand R
            while (R <= maxR) {
                add(nums[R]);
                ++R;
                rebalance();
            }

            // shrink left if previous iteration put L-1 in window
            // (for i>1, we must remove nums[i] which was previous L)
            if (L - 1 >= 2 && L - 1 < R) {
                rem(nums[L - 1]);
                rebalance();
            }

            if ((int)big.size() == k - 2) {
                long long cur = (long long)nums[0] + nums[i] + sumBig;
                ans = min(ans, cur);
            }
        }

        return ans;
    }
};
