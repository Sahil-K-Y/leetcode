class Solution {
public:
    int minimumDifference(vector<int>& nums, int k) {
        if (k == 1) {
            return 0;
        }
        sort(nums.begin(), nums.end());
        int n = nums.size();
        int ans = INT_MAX;

        // we just need to consider all consecutive windows of size k
        for (int i = 0; i + k - 1 < n; i++) {
            int curr = nums[i + k - 1] - nums[i];  // max - min in this window
            ans = min(ans, curr);
        }
        return ans;
    }
};
