class Solution:
    def canPartitionGrid(self, grid: List[List[int]]) -> bool:
        total=0
        m=len(grid)
        n=len(grid[0])
        total=sum(sum(rows) for rows in grid)
        r=0
        for i in range(m):
            r+=sum(grid[i])
            if r*2==total:
                return True
        c=0
        for j in range(n):
            col=0
            for i in range(m):
                col+=grid[i][j]
            c+=col
            if c*2==total:
                return True
        return False
