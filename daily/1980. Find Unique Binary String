class Solution {
public:
    string dectobin(int n){
        string bin="";
        while(n>0){
            int dig=n%2;
            bin+=dig+'0';
            n/=2;
        }
        reverse(bin.begin(),bin.end());
        return bin;
    }
    string findDifferentBinaryString(vector<string>& nums){
        int n=nums[0].size();
        unordered_set<string>s;
        for(auto bin:nums){
            s.insert(bin);
        }
        for(int i=0;i<(1<<n);i++){
            string bin=dectobin(i);
            while(bin.size()<n){
                bin="0"+bin;
            }
            if(s.count(bin)==0){
                return bin;
            }
        }
        return "";
    }
};
