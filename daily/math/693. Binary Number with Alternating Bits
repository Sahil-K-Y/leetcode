class Solution {
public:
    bool hasAlternatingBits(int n) {
        int prev = n & 1;   // get last bit
        n >>= 1;            // shift right
        while (n > 0) {
            int curr = n & 1;   // current bit
            if (curr == prev) return false; // two same bits in a row
            prev = curr;
            n >>= 1;
        }
        return true;
    }
};
