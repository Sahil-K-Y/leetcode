class Solution {
public:
    vector<int> minBitwiseArray(vector<int>& nums) {
        int n=nums.size();
        vector<int>ans(n);
        for(int i=0;i<n;i++){
            int j=1;
            while(j<nums[i]){
                if((j|(j+1))==nums[i]){
                    ans[i]=j;
                    break;
                }
                j++;
            }
            if(j==nums[i]){
                ans[i]=-1;
            }
        }
        return ans;
    }
};
