class Solution {
public:
    int longestBalanced(string s) {
        int n = s.length();
        int ans = 0;
        for(int i=0;i<n;i++){
            vector<int> freq(26,0);
            int distinct = 0;
            int maxFreq = 0;
            for(int j=i;j<n;j++){
                if(freq[s[j]-'a'] == 0){
                    distinct++;
                }
                freq[s[j]-'a']++;
                maxFreq = max(maxFreq, freq[s[j]-'a']);
                if(j-i+1 == distinct*maxFreq){
                    ans = max(ans, j-i+1);
                }
            }
            
        }
        return ans;
    }
};
