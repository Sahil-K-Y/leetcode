class Solution {
public:
    bool checkprime(int n){
        if(n==2)return true;
        if(n==1)return false;
        for(int i=2;i*i<=n;i++){
            if(n%i==0){
                return false;
            }
        }
        return true;
    }
    int countPrimeSetBits(int left, int right) {
        int temp=left;
        int ans=0;
        while(temp<=right){
            int x=temp;
            int count=0;
            while(x>0){
                if(x%2==1)count++;
                x/=2;
            }
            if(checkprime(count))ans++;
            temp++;
        }
        return ans;
    }
};
