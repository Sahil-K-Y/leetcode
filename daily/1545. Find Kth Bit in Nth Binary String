class Solution {
public:
    char findKthBit(int n, int k) {
        // Base case
        if (n == 1) return '0';

        int length = (1 << n) - 1;   // length of S_n
        int mid = (length / 2) + 1;  // middle position

        if (k == mid) return '1';
        else if (k < mid) {
            return findKthBit(n - 1, k);
        } else {
            // Mirror position in left half
            char bit = findKthBit(n - 1, length - k + 1);
            return (bit == '0') ? '1' : '0'; // invert
        }
    }
};
