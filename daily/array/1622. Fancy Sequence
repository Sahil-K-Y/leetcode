class Fancy {
public:
    vector<long long> arr;
    long long add;
    long long mul;
    long long MOD = 1e9 + 7;

    Fancy() {
        add = 0;
        mul = 1;
    }

    long long power(long long a,long long b){
        long long res = 1;
        while(b){
            if(b % 2) res = (res * a) % MOD;
            a = (a * a) % MOD;
            b /= 2;
        }
        return res;
    }
    
    void append(int val) {
        long long inv = power(mul, MOD-2);
        long long x = (val - add + MOD) % MOD;
        x = (x * inv) % MOD;
        arr.push_back(x);
    }
    
    void addAll(int inc) {
        add = (add + inc) % MOD;
    }
    
    void multAll(int m) {
        mul = (mul * m) % MOD;
        add = (add * m) % MOD;
    }
    
    int getIndex(int idx) {
        if(idx >= arr.size()) return -1;
        return (arr[idx] * mul % MOD + add) % MOD;
    }
};
