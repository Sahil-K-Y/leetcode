class Solution {
public:
    int minimumPairRemoval(vector<int>& nums) {
        int n = nums.size();
        if (n <= 1) return 0;

        vector<long long> arr(nums.begin(), nums.end());

        // linked list via indices, -1 = none
        vector<int> left(n), right(n);
        for (int i = 0; i < n; ++i) {
            left[i] = i - 1;
            right[i] = (i + 1 < n ? i + 1 : -1);
        }

        auto dec = [&](int i, int j) {
            return i != -1 && j != -1 && arr[i] > arr[j];
        };

        int inv = 0;
        for (int i = 0; i + 1 < n; ++i)
            if (arr[i] > arr[i + 1]) inv++;

        using P = pair<long long,int>;
        set<P> st;

        auto add_pair = [&](int i) {
            int j = (i == -1 ? -1 : right[i]);
            if (i == -1 || j == -1) return;
            st.insert({arr[i] + arr[j], i});
        };

        auto erase_pair = [&](int i) {
            int j = (i == -1 ? -1 : right[i]);
            if (i == -1 || j == -1) return;
            auto it = st.find({arr[i] + arr[j], i});
            if (it != st.end()) st.erase(it);
        };

        for (int i = 0; i + 1 < n; ++i) add_pair(i);

        int ops = 0;

        while (inv > 0 && !st.empty()) {
            auto [sum, i] = *st.begin();
            st.erase(st.begin());
            int j = right[i];
            if (j == -1) continue;        // not valid anymore

            int L = left[i];
            int R = right[j];

            // decrease old inversions if they exist
            if (dec(L, i)) inv--;
            if (dec(i, j)) inv--;
            if (dec(j, R)) inv--;

            // remove involved pairs from set
            erase_pair(L);
            erase_pair(i);
            erase_pair(j);

            // merge j into i
            arr[i] += arr[j];

            // remove j from list
            right[i] = R;
            if (R != -1) left[R] = i;

            // add new inversions
            if (dec(L, i)) inv++;
            if (dec(i, R)) inv++;

            // add new pairs
            add_pair(L);
            add_pair(i);

            ops++;
        }

        return ops;
    }
};
