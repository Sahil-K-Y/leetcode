class Solution {
public:
    int longestBalanced(vector<int>& nums) {
        if(nums.size() == 0 || nums.size() == 1) return 0;
        int n = nums.size();
        int ans = 0;
        for(int i=0;i<n;i++){
            set<int> odd;
            set<int> even;
            for(int j=i;j<n;j++){
                if(nums[j]%2 == 0){
                    even.insert(nums[j]);
                }else{
                    odd.insert(nums[j]);
                }
                if(even.size() == odd.size()){
                    ans = max(ans, j-i+1);
                }
            }
        }
        return ans;
    }
};
