class Solution {
public:
    bool isTrionic(vector<int>& nums) {
        int n = nums.size();
        if (n < 4) return false;  // need room for 3 segments[web:3]

        int i = 0;

        // Phase 1: strictly increasing: nums[0...p]
        while (i + 1 < n && nums[i] < nums[i + 1]) {
            i++;
        }
        int p = i;
        if (p == 0) return false;  // no increasing segment[web:3]

        // Phase 2: strictly decreasing: nums[p...q]
        while (i + 1 < n && nums[i] > nums[i + 1]) {
            i++;
        }
        int q = i;
        // need at least one decreasing step and room for last increasing
        if (q == p || q == n - 1) return false;[web:3]

        // Phase 3: strictly increasing: nums[q...n-1]
        while (i + 1 < n && nums[i] < nums[i + 1]) {
            i++;
        }

        // Must end exactly at last index
        return i == n - 1;[web:3]
    }
};
