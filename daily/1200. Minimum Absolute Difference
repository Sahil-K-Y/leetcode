class Solution {
public:
    vector<vector<int>> minimumAbsDifference(vector<int>& arr) {
        sort(arr.begin(),arr.end());
        int n=arr.size();
        int curr=INT_MAX;
        vector<vector<int>>ans;
        for(int i=1;i<n;i++){
            curr=min(curr,arr[i]-arr[i-1]);
        }
        for(int i=1;i<n;i++){
            if(arr[i]-arr[i-1]==curr){
                ans.push_back({arr[i-1],arr[i]});
            }
        }
        return ans;
    }
};
