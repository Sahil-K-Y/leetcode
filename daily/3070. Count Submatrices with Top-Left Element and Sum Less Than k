class Solution {
public:
    int countSubmatrices(vector<vector<int>>& grid, int k) {
        int col=grid[0].size();
        int row=grid.size();
        int ans=0;
        vector<int>colsum(col,0);
        for(int i=0;i<row;i++){
            int csum=0;
            for(int j=0;j<col;j++){
                colsum[j]+=grid[i][j];
                csum+=colsum[j];
                if(csum<=k){
                    ans++;
                }else {
                    break;
                }
            }
        }
        return ans;
    }
};
