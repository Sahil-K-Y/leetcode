class Solution {
public:
    int minPairSum(vector<int>& nums) {
        sort(nums.begin(),nums.end());
        int i=0;
        int j=nums.size()-1;
        int maxsum=0;
        while(i<j){
            maxsum=max(maxsum,nums[i]+nums[j]);
            i++;
            j--;
        }
        return maxsum;
    }
};
